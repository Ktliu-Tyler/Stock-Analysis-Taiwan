# Copy this file to .env for local runs. Never commit .env.

# Scanner controls
AGENT_QUICK_MODE=false
AGENT_STOCKS=
AGENT_THRESHOLD=65
AGENT_OUTPUT_DIR=reports
AGENT_DRY_RUN=true

# Email notification
AGENT_SEND_EMAIL=false
EMAIL_PROVIDER=resend
EMAIL_FROM=Taiwan Stock Scanner <report@example.com>
EMAIL_TO=your-email@example.com
RESEND_API_KEY=

# SMTP fallback, used only when EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# LINE Messaging API notification
# LINE Notify ended on 2025-03-31; use Messaging API push messages instead.
AGENT_SEND_LINE=false
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO=

# Optional public URLs for LINE. LINE image messages require HTTPS image URLs.
LINE_REPORT_URL=
LINE_POSTER_IMAGE_URL=
